#!/bin/bash
# Generated by issue-orchestrator. Do not edit by hand — regenerated on app start.
#
# Wired into Claude Code's hook system via ~/.claude/settings.json. Forwards
# the hook's JSON payload (annotated with ISSUE_ORCH_SESSION_ID if the
# spawning process set one) to the orchestrator's Unix socket. If the
# socket isn't there (app not running) the script silently exits, so
# Claude sessions started outside the orchestrator are unaffected.

set -u

sock="${ISSUE_ORCH_SOCK:-$HOME/Library/Application Support/dev.jonasross.issue-orchestrator/hooks.sock}"

if [ ! -S "$sock" ]; then
  exit 0
fi

payload=$(cat)
if [ -n "${ISSUE_ORCH_SESSION_ID:-}" ] && command -v jq >/dev/null 2>&1; then
  payload=$(echo "$payload" | jq --arg orch_id "$ISSUE_ORCH_SESSION_ID" '. + {session_orch_id: $orch_id}')
fi

echo "$payload" | nc -U "$sock" -w 1 2>/dev/null || true
