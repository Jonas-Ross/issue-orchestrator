{
  "name": "issue-orchestrator",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "npm run bindings",
    "dev": "vite",
    "prebuild": "npm run bindings",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "bindings": "cargo run --manifest-path src-tauri/Cargo.toml --bin export-bindings --quiet",
    "tauri": "tauri",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "NODE_OPTIONS=--no-webstorage vitest run",
    "test:watch": "NODE_OPTIONS=--no-webstorage vitest",
    "test:cov": "NODE_OPTIONS=--no-webstorage vitest run --coverage"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vite": "^8.0",
    "vitest": "^4.1.5"
  }
}
